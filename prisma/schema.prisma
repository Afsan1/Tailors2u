generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Booking {

  id        String   @id @default(cuid())

  name      String
  email     String
  phone     String
  address   String?

  service   String

  date       DateTime
  time       String

  notes      String?
  clerkUserId String?

  createdAt DateTime @default(now())
}